---
import { getCollection } from 'astro:content';

const blogPosts = await getCollection('blog');
const hasBlog = blogPosts.length > 0;
const currentPath = Astro.url.pathname;
---

<nav class="w-full px-8 sm:px-12 py-4 border-b border-slate-800/50 flex items-center justify-between">
	<a href="/" class="text-lg font-semibold text-white hover:text-cyan-400 transition-colors font-mono tracking-tight">
		EG<span class="text-cyan-400">.</span>
	</a>

	<div class="flex items-center gap-1">
		<a
			href="/"
			class:list={[
				'px-4 py-2 text-sm font-medium rounded-lg transition-all',
				currentPath === '/'
					? 'text-cyan-400 bg-cyan-950/30'
					: 'text-slate-300 hover:text-white hover:bg-slate-800/50',
			]}
		>
			Home
		</a>

		{hasBlog && (
			<a
				href="/blog"
				class:list={[
					'px-4 py-2 text-sm font-medium rounded-lg transition-all',
					currentPath.startsWith('/blog')
						? 'text-cyan-400 bg-cyan-950/30'
						: 'text-slate-300 hover:text-white hover:bg-slate-800/50',
				]}
			>
				Blog
			</a>
		)}
	</div>
</nav>
