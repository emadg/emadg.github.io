---
import '../styles/global.css';
import NetworkBackground from '../components/NetworkBackground.astro';
import Nav from '../components/Nav.astro';

interface Props {
	title: string;
	description?: string;
	scrollSnap?: boolean;
}

const { title, description = "Machine Learning Developer Portfolio & Resume", scrollSnap = false } = Astro.props;
---

<!doctype html>
<html lang="en" class="scroll-smooth" style={scrollSnap ? "scroll-snap-type: y proximity;" : ""}>
	<head>
		<meta charset="UTF-8" />
		<meta name="description" content={description} />
		<meta name="viewport" content="width=device-width" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<meta name="generator" content={Astro.generator} />
		<title>{title}</title>
		
		<!-- Theme Script to prevent flash of wrong theme -->
		<script is:inline>
			const theme = (() => {
				if (typeof localStorage !== 'undefined' && localStorage.getItem('theme')) {
					return localStorage.getItem('theme');
				}
				if (window.matchMedia('(prefers-color-scheme: dark)').matches) {
					return 'dark';
				}
				return 'light';
			})();
		
			if (theme === 'dark') {
				document.documentElement.classList.add('dark');
			} else {
				document.documentElement.classList.remove('dark');
			}
		
			window.localStorage.setItem('theme', theme);
		</script>
	</head>
	<body class="min-h-screen flex flex-col items-center relative overflow-x-hidden">
		<!-- Animated Canvas Background -->
		<NetworkBackground />
		
		<!-- Central Frosted Glass Panel -->
		<div class="w-full max-w-5xl min-h-screen flex flex-col items-center bg-bg-panel backdrop-blur-[5px] border-x border-border-subtle shadow-2xl relative z-10 transform-gpu">
			
			<Nav scrollSnap={scrollSnap} />

			<main class="w-full px-8 sm:px-12 py-12 md:py-24 flex-grow flex flex-col">
				<slot />
			</main>

			<!-- Minimal Footer inside the panel -->
			<footer class="w-full px-8 sm:px-12 py-8 mt-auto border-t border-border-subtle">
				<div class="flex justify-between items-center text-sm text-text-muted">
				<p>&copy; {new Date().getFullYear()} Emad Gohari</p>
				<div class="flex gap-4">
						<a href="https://github.com/emadg" target="_blank" rel="noopener noreferrer" class="hover:text-accent transition-colors">GitHub</a>
						<a href="https://www.linkedin.com/in/emad-gohari" target="_blank" rel="noopener noreferrer" class="hover:text-accent transition-colors">LinkedIn</a>
					</div>
				</div>
			</footer>
		</div>
	</body>
</html>
